# Temp/local directories
temp/

# Build artifacts
/build/
/dist/

# Compiled GUI binary (produced by `go build`/`wails3` inside the gui package,
# named after its directory; the real release binary lives under /build/)
/gui/gui

# Frontend
gui/frontend/node_modules/
gui/frontend/dist/

# Embedded GUI helper (regenerated by scripts/build.sh; only .gitkeep is committed)
internal/launcher/assets/*.gz

# Staged print bundle for PDF export (regenerated by the build scripts; only
# .gitkeep is committed)
internal/pdf/assets/dist/

# Generated Windows resource objects (icon/manifest/version), produced per build
# by scripts/build.ps1 via scripts/winres.
*.syso

# OS / editor
.DS_Store
*.log

# Test / coverage output
coverage.out
coverage.html
